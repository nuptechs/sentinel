{
  "name": "@nuptech/sentinel",
  "version": "0.1.0",
  "type": "module",
  "description": "QA capture → diagnosis → correction pipeline with hexagonal architecture",
  "exports": {
    ".": "./src/index.js",
    "./core/*": "./src/core/*.js",
    "./adapters/*": "./src/adapters/*.js",
    "./server": "./src/server/index.js",
    "./sdk": "./src/sdk/index.js"
  },
  "scripts": {
    "dev": "node --watch src/server/index.js",
    "start": "node src/server/index.js",
    "test": "node --test tests/**/*.test.js",
    "lint": "eslint src/"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "compression": "^1.8.0",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "pg": "^8.13.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "eslint": "^9.0.0"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "html2canvas": ">=1.4.0",
    "openai": ">=4.0.0",
    "rrweb": ">=2.0.0-alpha.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "openai": {
      "optional": true
    },
    "rrweb": {
      "optional": true
    },
    "html2canvas": {
      "optional": true
    }
  }
}
