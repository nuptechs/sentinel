{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 0,
  "id": null,
  "links": [],
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum by (method, route) (rate(sentinel_http_requests_total[5m]))",
          "legendFormat": "{{method}} {{route}}"
        }
      ]
    },
    {
      "title": "HTTP p95 Latency",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, route) (rate(sentinel_http_request_duration_seconds_bucket[5m])))",
          "legendFormat": "p95 {{route}}"
        }
      ]
    },
    {
      "title": "Error Rate (5xx %)",
      "type": "stat",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "sum(rate(sentinel_http_requests_total{status_code=~\"5..\"}[5m])) / sum(rate(sentinel_http_requests_total[5m])) * 100",
          "legendFormat": "error %"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 1 },
              { "color": "red", "value": 5 }
            ]
          }
        }
      }
    },
    {
      "title": "Findings Created (rate/min)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 9, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "sum by (source, type) (rate(sentinel_findings_created_total[5m])) * 60",
          "legendFormat": "{{source}}/{{type}}"
        }
      ]
    },
    {
      "title": "Diagnoses by Outcome (rate)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 9, "x": 15, "y": 8 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(sentinel_diagnoses_total[5m]))",
          "legendFormat": "{{outcome}}"
        }
      ]
    },
    {
      "title": "Diagnosis Duration (p50/p95)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum by (le) (rate(sentinel_diagnosis_duration_seconds_bucket[5m])))",
          "legendFormat": "p50"
        },
        {
          "expr": "histogram_quantile(0.95, sum by (le) (rate(sentinel_diagnosis_duration_seconds_bucket[5m])))",
          "legendFormat": "p95"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Auto-Enrich Outcomes (rate)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "sum by (outcome) (rate(sentinel_auto_enrich_total[5m]))",
          "legendFormat": "{{outcome}}"
        },
        {
          "expr": "sum by (outcome) (rate(sentinel_enrich_live_total[5m]))",
          "legendFormat": "live/{{outcome}}"
        }
      ]
    },
    {
      "title": "Process Memory (RSS)",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "sentinel_process_resident_memory_bytes",
          "legendFormat": "RSS"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "bytes" } }
    },
    {
      "title": "Event Loop Lag p99",
      "type": "timeseries",
      "datasource": "Prometheus",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        {
          "expr": "sentinel_nodejs_eventloop_lag_p99_seconds",
          "legendFormat": "p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["sentinel"],
  "templating": { "list": [] },
  "time": { "from": "now-1h", "to": "now" },
  "title": "Sentinel Overview",
  "uid": "sentinel-overview"
}
